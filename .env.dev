# Davo-AI · DEV environment (Mac M4 + Mock servers)
# Скопировать в .env: cp .env.dev .env
# Затем заполнить TELEGRAM_BOT_TOKEN

# ═══ Telegram ═══
TELEGRAM_BOT_TOKEN=your-bot-token-from-BotFather
TELEGRAM_BOT_USERNAME=DavoAIDevBot
USE_LOCAL_BOT_API=false

# ═══ Mock inference servers (один процесс, все эндпоинты) ═══
# Запуск: python packages/inference/mock_servers.py
LLM_API_URL=http://localhost:9000/v1
LLM_MODEL=aya-expanse-32b
VISION_API_URL=http://localhost:9000/v1
VISION_MODEL=qwen-vl
WHISPER_API_URL=http://localhost:9000/whisper
YOLO_API_URL=http://localhost:9000/yolo
VERIFIER_API_URL=http://localhost:9000/verifier

# ═══ Database (через docker-compose) ═══
POSTGRES_USER=davoai
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=davoai
DATABASE_URL=postgresql+asyncpg://davoai:devpassword@localhost:5432/davoai

# ═══ Storage ═══
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/videos

# ═══ App ═══
APP_ENV=development
LOG_LEVEL=DEBUG
DEFAULT_LANGUAGE=uz
TIMEZONE=Asia/Tashkent

# ═══ Features ═══
ENABLE_VOICE_INPUT=true
ENABLE_PEDIATRIC_MODULE=false
ENABLE_DROP_OFF_ML=false

# ═══ Reminders ═══
DEFAULT_REMINDER_TIME=08:00
REMINDER_RETRY_INTERVAL_MINUTES=30
MAX_REMINDER_RETRIES=3
