# ──────────────────────────────────────────────────────────────────────────
# TB Control · Inference backends
#
# Pick ONE of three modes:
#   1. Kaggle  (recommended for hackathon — free 30h/week 2× T4)
#   2. vast.ai (legacy — direct GPU, port-routing, $0.59/hr)
#   3. Mock    (no backend — convincing visualization, face-api still real)
# ──────────────────────────────────────────────────────────────────────────

# ── Mode 1: Kaggle (paste tunnel URL from notebook output) ───────────────
# NEXT_PUBLIC_KAGGLE_INFERENCE_URL=https://abc-def-ghi.trycloudflare.com

# ── Mode 2: vast.ai (port-based routing) ─────────────────────────────────
# NEXT_PUBLIC_VAST_INFERENCE_URL=https://your-vast-host.com

# ── Mode 3: Mock (default if no URL set above) ───────────────────────────
NEXT_PUBLIC_USE_MOCK_INFERENCE=true

# ── Telegram bot (gitignored separately) ─────────────────────────────────
# TELEGRAM_BOT_TOKEN=...
