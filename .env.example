# ════════════════════════════════════════════════════════════
# Davo-AI · MindTech · AI HEALTH Hackathon 2026
# ════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. Never commit .env to git.

# ─── Telegram Bot ────────────────────────────────────
# Получить через @BotFather в Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=DavoAIBot

# Local Telegram Bot API server (для видео >20 MB)
# Запускается через docker-compose в infra/docker
TELEGRAM_LOCAL_API_URL=http://localhost:8081
USE_LOCAL_BOT_API=true

# ─── Inference Endpoints (vast.ai RTX 5090) ──────────
# Production: vast.ai instance в Slovenia datacenter
# Dev (Mac M4 + mock servers): localhost:9000
# DGX Spark fallback (если вернётся): spark-5.idrock.uz
INFERENCE_HOST=212.13.234.30
INFERENCE_SSH_PORT=1879

# vLLM serving Aya Expanse 32B AWQ (квантованная под 32GB VRAM)
# Fallback: Qwen2.5-32B-Instruct-AWQ или Qwen2.5-14B AWQ
LLM_API_URL=http://212.13.234.30:8001/v1
LLM_MODEL=davoai-llm
LLM_API_KEY=local-no-auth

# Vision serving Qwen2.5-VL-7B AWQ (~7 GB VRAM)
VISION_API_URL=http://212.13.234.30:8002/v1
VISION_MODEL=davoai-vision

# Whisper Large-v3-Turbo (faster-whisper INT8 ~1.5 GB)
WHISPER_API_URL=http://212.13.234.30:8003
WHISPER_MODEL=large-v3-turbo

# YOLOv8 fine-tuned на TB pills (после training)
YOLO_API_URL=http://212.13.234.30:8004
YOLO_MODEL_PATH=runs/detect/tb_pills_v1/weights/best.pt

# Verifier orchestrator (объединяет YOLO + Vision)
VERIFIER_API_URL=http://212.13.234.30:8005

# ─── Database ────────────────────────────────────────
# Local Postgres (через docker-compose) или Supabase
# ВАЖНО: установи свой POSTGRES_PASSWORD ниже и используй его в DATABASE_URL
POSTGRES_USER=davoai
POSTGRES_PASSWORD=
POSTGRES_DB=davoai
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
DATABASE_POOL_SIZE=10

# pgAdmin (только профиль "debug" в docker-compose)
PGADMIN_EMAIL=admin@local
PGADMIN_PASSWORD=

# Supabase (если используем для prototype dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Storage (видео-файлы) ───────────────────────────
# Опции: local | supabase | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/videos
# Только если STORAGE_BACKEND=supabase
SUPABASE_BUCKET=patient-videos
# Только если STORAGE_BACKEND=s3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Doctor Dashboard Auth (Clerk) ───────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Application ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru
TIMEZONE=Asia/Tashkent

# ─── Feature flags ───────────────────────────────────
ENABLE_VOICE_INPUT=true
ENABLE_PEDIATRIC_MODULE=false
ENABLE_DROP_OFF_ML=false

# ─── Reminders ───────────────────────────────────────
DEFAULT_REMINDER_TIME=08:00
REMINDER_RETRY_INTERVAL_MINUTES=30
MAX_REMINDER_RETRIES=3
