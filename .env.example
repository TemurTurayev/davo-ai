# ════════════════════════════════════════════════════════════
# Davo-AI · MindTech · AI HEALTH Hackathon 2026
# ════════════════════════════════════════════════════════════
# Copy to .env and fill in real values. Never commit .env to git.

# ─── Telegram Bot ────────────────────────────────────
# Получить через @BotFather в Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=DavoAIBot

# Local Telegram Bot API server (для видео >20 MB)
# Запускается через docker-compose в infra/docker
TELEGRAM_LOCAL_API_URL=http://localhost:8081
USE_LOCAL_BOT_API=true

# ─── DGX Spark Inference Endpoints ───────────────────
# Cloudflared tunnel или Tailscale
# Production: spark-5.idrock.uz
# Dev (Mac M4 + Ollama): localhost
DGX_HOST=spark-5.idrock.uz
DGX_USE_TUNNEL=true

# vLLM serving Aya Expanse 32B / Qwen2.5-72B
LLM_API_URL=https://spark-5.idrock.uz/v1
LLM_MODEL=CohereForAI/aya-expanse-32b
LLM_API_KEY=local-no-auth

# Vision serving Qwen2.5-VL-7B
VISION_API_URL=https://spark-5.idrock.uz:8002/v1
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Whisper Large-v3-Turbo (faster-whisper)
WHISPER_API_URL=https://spark-5.idrock.uz:8003
WHISPER_MODEL=large-v3-turbo

# YOLOv8 fine-tuned on TB pills
YOLO_API_URL=https://spark-5.idrock.uz:8004
YOLO_MODEL_PATH=runs/detect/tb_pills_v1/weights/best.pt

# ─── Database ────────────────────────────────────────
# Local Postgres or Supabase
DATABASE_URL=postgresql://davoai:davoai@localhost:5432/davoai
DATABASE_POOL_SIZE=10

# Supabase (если используем для prototype dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Storage (видео-файлы) ───────────────────────────
# Опции: local | supabase | s3
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/videos
# Только если STORAGE_BACKEND=supabase
SUPABASE_BUCKET=patient-videos
# Только если STORAGE_BACKEND=s3
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Doctor Dashboard Auth (Clerk) ───────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Application ─────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=uz
SUPPORTED_LANGUAGES=uz,ru
TIMEZONE=Asia/Tashkent

# ─── Feature flags ───────────────────────────────────
ENABLE_VOICE_INPUT=true
ENABLE_PEDIATRIC_MODULE=false
ENABLE_DROP_OFF_ML=false

# ─── Reminders ───────────────────────────────────────
DEFAULT_REMINDER_TIME=08:00
REMINDER_RETRY_INTERVAL_MINUTES=30
MAX_REMINDER_RETRIES=3
